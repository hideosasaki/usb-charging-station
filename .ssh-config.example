# Append a block like this to ~/.ssh/config on the dev machine.
# Replace <pi-hostname-or-ip> and <user> with your values.
# The "Host" alias must match PI_HOST in .env.

Host pi-zero
    HostName <pi-hostname-or-ip>
    User <user>
    IdentityFile ~/.ssh/id_ed25519
    ServerAliveInterval 30
    ControlMaster auto
    ControlPath ~/.ssh/cm-%r@%h:%p
    ControlPersist 10m
